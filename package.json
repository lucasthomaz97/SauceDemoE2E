{
  "name": "sauce_e2e_test",
  "version": "1.0.0",
  "description": "E2E automated tests for SauceDemo using Playwright",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:chromium": "npx playwright test --project chromium",
    "test:all": "npx playwright test --project chromium --project firefox --project webkit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasthomaz97/SauceDemoE2E.git"
  },
  "keywords": [
    "Playwright",
    "Test",
    "Automation",
    "NodeJs",
    "Typescript",
    "E2E"
  ],
  "author": "Lucas Thomaz",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/lucasthomaz97/SauceDemoE2E/issues"
  },
  "homepage": "https://github.com/lucasthomaz97/SauceDemoE2E#readme",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2"
  }
}
